# === Data Engine .gitignore ===
# The repo tracks CODE only. Scraped data + backups are large/derived and stay out.

# --- scraped data (rebuildable; ~2.6 GB) ---
mergr_companies/
mergr_investors/
mergr_transactions/
mergr_txn_details/
embeddings/
*.jsonl
*.state

# --- DB snapshots / dumps ---
*.sql.gz
*.dump

# --- id lists, logs, scratch text ---
mergr_*ids*.txt
mergr_skip_ids*
mergr_missing_*.txt
mergr_investor_urls.txt
mergr_companies_with_revenue*.txt
mergr_txn_needs_parties.txt
*.log

# --- saved HTML / CSV / sample payloads ---
*.html
*.csv
mergr_sample.json
match_results.json

# --- separate Laravel backup app (not part of Data Engine) ---
origryxd/
origryxd-*/

# --- entity-lookup source (self-contained app) ---
# keep its test fixtures despite the global *.html rule (they're the porting oracle)
!sources/entity/tests/fixtures/*.html
# but never track its runtime artifacts
sources/entity/php/cache/
sources/entity/php/build.json
sources/entity/php/node_modules/
# recognized secrets externalised out of the repo (GitHub push protection)
*.secrets.env

# --- python / tooling / os ---
__pycache__/
*.pyc
.DS_Store
.claude/
mergr_scraper_rust/

# entity Python app runtime output
sources/entity/app/reports/
sources/entity/app/__pycache__/

# ad-hoc mergr scraper scratch (not part of the app)
mergr_explore.py
mergr_test_*.py
mergr_*.json

# web UI Jinja templates are source, not scraped HTML — keep despite the global *.html rule
!mergr_db/templates/*.html
